# PostgreSQL Database Configuration
# These variables are used by the docker-compose.yml to set up the database container.
POSTGRES_USER=trading_user
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=trading_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Application Configuration
# This single URL is used by the application to connect to the database.
# It's constructed from the variables above.
DATABASE_URL=postgresql://trading_user:your_strong_password_here@db:5432/trading_db

# API Security Configuration
# This key is required for the Database Agent to accept requests.
# Generate a secure key, e.g., using: openssl rand -hex 32
DATABASE_AGENT_API_KEY=

# Alpaca API Credentials
# These are required to fetch market data from Alpaca.
# Sign up for a free account at https://alpaca.markets/
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
