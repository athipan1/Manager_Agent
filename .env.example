# Manager Agent

DEFAULT_ACCOUNT_ID=1

# Agent URLs
TECHNICAL_AGENT_URL=http://technical-agent:8002
FUNDAMENTAL_AGENT_URL=http://fundamental-agent:8001
SCANNER_AGENT_URL=http://scanner-agent:8003
DATABASE_AGENT_URL=http://database-agent:8004
AUTO_LEARNING_AGENT_URL=http://learning-agent:8005
RISK_AGENT_URL=http://risk-agent:8007
EXECUTION_AGENT_URL=http://execution-agent:8006

# API keys for service-to-service calls
DATABASE_AGENT_API_KEY=replace_me
EXECUTION_API_KEY=replace_me

# Important: Manager_Agent must not connect to PostgreSQL directly.
# Do not set DATABASE_URL here. Only Database_Agent should own DATABASE_URL.

# Risk settings used as input defaults before external Risk_Agent approval
RISK_PER_TRADE=0.01
STOP_LOSS_PERCENTAGE=0.03
MAX_POSITION_PERCENTAGE=0.10
MAX_TOTAL_EXPOSURE=0.50
PER_REQUEST_RISK_BUDGET=0.05
MIN_POSITION_VALUE=500
